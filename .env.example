# Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/npc_dialogue

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Worldbuilding documents directory
WORLDBUILDING_DIR=./worldbuilding

# Embedding model
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Reranker model
RERANKER_MODEL=cross-encoder/ms-marco-multilingual-MiniLM-L12-v2

# Search weights (must sum to 1.0)
VECTOR_SEARCH_WEIGHT=0.7
BM25_SEARCH_WEIGHT=0.3

# Number of top results to return
TOP_K=5

# Semantic cache similarity threshold
SEMANTIC_CACHE_THRESHOLD=0.95

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# LLM model name
LLM_MODEL=gemini-2.0-flash
